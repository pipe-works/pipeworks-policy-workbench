# Policy Workbench runtime defaults
#
# Copy this file to `.env` and edit values as needed.
# Existing exported environment variables take precedence over `.env`.
#
# This example file now reflects the Luminal host-preparation direction for the
# PipeWorks workspace rooted at `/srv/work/pipeworks`.

# Default URLs shown for Policy Source Mode options.
# These remain editable in the UI runtime mode controls.
PW_POLICY_DEV_MUD_API_BASE_URL=http://127.0.0.1:8000

# Leave production unset here until the intended production target is confirmed.
# The runtime-mode code still supports PW_POLICY_PROD_MUD_API_BASE_URL when you
# want to supply it explicitly in a real environment file.
# PW_POLICY_PROD_MUD_API_BASE_URL=

# Canonical policy root for CLI validation flows.
# Update this if the active Luminal canonical source is moved elsewhere.
PW_POLICY_CANONICAL_ROOT=/srv/work/pipeworks/repos/pipeworks_mud_server/data/worlds/pipeworks_web/policies

# Optional default server port for `pw-policy serve`.
# Leave blank to keep current behavior (first available port in 8000-8099).
PW_POLICY_DEFAULT_PORT=
