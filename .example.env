# Policy Workbench runtime defaults
#
# Copy this file to `.env` and edit values as needed.
# Existing exported environment variables take precedence over `.env`.

# Default URLs shown for Policy Source Mode options.
# These remain editable in the UI runtime mode controls.
PW_POLICY_DEV_MUD_API_BASE_URL=http://127.0.0.1:8000
PW_POLICY_PROD_MUD_API_BASE_URL=https://api.pipe-works.org

# Optional default server port for `pw-policy serve`.
# Leave blank to keep current behavior (first available port in 8000-8099).
PW_POLICY_DEFAULT_PORT=
