# PipeWorks Policy Workbench runtime settings for systemd.
PW_POLICY_SERVICE_HOST=127.0.0.1
PW_POLICY_SERVICE_PORT=8040

# Point the workbench at the host-local mud-server runtime for browser testing.
PW_POLICY_SOURCE_MODE=server_dev
PW_POLICY_DEV_MUD_API_BASE_URL=http://127.0.0.1:18000

# Leave production explicit. Do not copy a stale target here by default.
# PW_POLICY_PROD_MUD_API_BASE_URL=

PW_POLICY_CANONICAL_ROOT=/srv/work/pipeworks/repos/pipeworks_mud_server/data/worlds/pipeworks_web/policies
